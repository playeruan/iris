include "bindings/libc.iris"
include "bindings/raylib.iris"

main: () -> i32 {
  init_window(900, 600, "test");
  set_target_fps(60);

  printf("initialized window\n");

  c: Color = Color(0, 255, 0, 255);
  c.b = 255;

  while !window_should_close() {
    begin_drawing();
    clear_background(c);
    end_drawing();
  }

  printf("closing window\n");

  ret 0;
}

